{
  "name": "emocare-desktop-pet",
  "version": "0.1.0",
  "description": "EmoCare 桌面宠物 - 情感陪伴助手",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "electron": "electron .",
    "start": "npm run build && npm run electron",
    "package": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.emocare.desktop-pet",
    "productName": "EmoCare 小暖",
    "win": {
      "target": "nsis",
      "icon": "src/renderer/assets/icon.ico"
    },
    "files": [
      "dist/**/*",
      "src/renderer/assets/**/*"
    ]
  }
}
